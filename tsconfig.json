{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["sidepanel/*"],
      "@src/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "background/**/*.ts", "sidepanel/**/*.ts", "sidepanel/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
